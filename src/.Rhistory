setwd("C:/Users/konaffioustg/Downloads/SPG V1/src")
# 1. Vérifier que vous êtes au bon endroit
getwd()
# 2. Lister les fichiers pour confirmer la présence du fichier .cpp
list.files(pattern = "\\.cpp$")
# 3. Compiler le code source
library(Rcpp)
sourceCpp("fst_permute_bootstrap_OpenMP.cpp", verbose = TRUE)
# Utilisez le nom exact du fichier (avec la faute d'orthographe)
sourceCpp("fst_permute_boostrap_OpenMP.cpp", verbose = TRUE)
# 1. Vérifier que la fonction est chargée
exists("batch_permute_g_stat_parallel")
# 2. Voir les arguments de la fonction
args(batch_permute_g_stat_parallel)
# 3. Tester avec des données minimales
set.seed(123)
n_ind <- 50
n_loci <- 5
n_pops <- 3
base <- 1000
# Créer une matrice de test
test_mat <- matrix(0L, nrow = n_ind, ncol = n_loci + 1)
test_mat[,1] <- sample(1:n_pops, n_ind, replace = TRUE)  # Populations
# Générer des génotypes
for(i in 1:n_ind) {
for(j in 2:(n_loci+1)) {
test_mat[i, j] <- (sample(1:10, 1)) * base + sample(1:10, 1)
}
}
# Convertir en IntegerMatrix Rcpp
test_data <- as.integer(test_mat)
dim(test_data) <- dim(test_mat)
# Exécuter le test G
resultats_G <- batch_permute_g_stat_parallel(
dat = test_data,
pop_col_1based = 1,
missing_code = 0,
base = 1000,
B = 100,  # Petit nombre pour le test rapide
n_threads = 2,
seed = 123
)
# Afficher les résultats
print("P-value globale du test G:")
print(resultats_G$p_G_overall)
print("Premières p-values par locus:")
print(head(resultats_G$p_G))
# Structure complète des résultats
str(resultats_G)
