# Vérifier qu'il a disparu
exists("batch_permute_g_stat_parallel")
# Nettoyer les DLL temporaires
unlink(list.files(tempdir(), pattern = "sourceCpp.*\\.dll$", full.names = TRUE))
unlink(list.files(tempdir(), pattern = "sourceCpp.*\\.so$", full.names = TRUE))
# Nettoyer le cache de sourceCpp
unlink(list.files(tempdir(), pattern = "RcppExports.*", full.names = TRUE), recursive = TRUE)
library(Rcpp)
# Option 1: Compilation forcée avec rebuild
sourceCpp("fst_permute_boostrap_OpenMP.cpp", rebuild = TRUE, verbose = TRUE)
# Après compilation, vérifier
print(class(batch_permute_g_stat_parallel))
# Vérifier que c'est bien une fonction
class(batch_permute_g_stat_parallel)  # [1] "function"
mode(batch_permute_g_stat_parallel)   # [1] "function"
# Voir les arguments
args(batch_permute_g_stat_parallel)
# Tester avec des données factices
set.seed(123)
n_ind <- 50
n_loci <- 5
n_pops <- 3
base <- 1000
# Créer une matrice de test
test_mat <- matrix(0L, nrow = n_ind, ncol = n_loci + 1)
test_mat[,1] <- sample(1:n_pops, n_ind, replace = TRUE)  # Populations
# Générer des génotypes aléatoires
for(i in 1:n_ind) {
for(j in 2:(n_loci+1)) {
a1 <- sample(1:10, 1)
a2 <- sample(1:10, 1)
test_mat[i, j] <- a1 * base + a2
}
}
# Exécuter le test G
resultats_G <- batch_permute_g_stat_parallel(
dat = test_mat,
pop_col_1based = 1,
missing_code = 0,
base = 1000,
B = 100,  # Petit nombre pour test rapide
n_threads = 2,
seed = 123
)
# Afficher les résultats
print("=== RÉSULTATS DU TEST G ===")
print(paste("P-value globale:", resultats_G$p_G_overall))
print(paste("G observé global:", resultats_G$G_overall_obs))
print("\nP-values par locus:")
print(resultats_G$p_G)
print("\nG observé par locus:")
print(resultats_G$G_locus_obs)
# Structure complète
names(resultats_G)
